# E2e test-target configuration for this workspace's CLI crates.
#
# Copy this file to `.env` (gitignored, never committed) and fill in real
# values. `.env` is loaded automatically by each crate's e2e test suite
# (`dotenvy::dotenv()`, called at the top of each crate's `setup()` in
# `src/tests/e2e_tests.rs`) — no need to export these manually before
# running `cargo test -p <crate> -- --ignored`. An already-exported shell
# env var still takes precedence over `.env` (dotenvy never overrides an
# existing value), so `JIRA_E2E_PROJECT=OTHER cargo test ...` still works
# for a one-off override.

# jira: a writable Jira project key that allows creating/deleting Task
# issues. See crates/jira/README.md's "Testing" section.
JIRA_E2E_PROJECT=YOUR_PROJECT_KEY

# google-chat: a Chat space safe for read-only e2e checks (and, once
# BACKLOG.md's GCHAT-2 is unblocked, disposable send+delete cycles). Full
# resource name, e.g. "spaces/AAAAAAAAAAA". See
# crates/google-chat/README.md's "Testing" section.
GOOGLE_CHAT_E2E_SPACE=spaces/YOUR_TEST_SPACE_ID
